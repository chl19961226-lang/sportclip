# OpenAI / 兼容接口（可选）。留空则启用本地 mock 启发式。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini

# YOLO 模型权重（首次会自动下载）
YOLO_WEIGHTS=yolov8n.pt

# 本地存储目录（相对 backend/）
STORAGE_DIR=storage

# 关键帧采样：每 N 秒抽 1 帧
SAMPLE_INTERVAL_SEC=1.5

# 高光片段时长（秒）
CLIP_DURATION_SEC=3.0
# 单视频最多保留的高光数
MAX_CLIPS=8

# 允许的前端来源（精确列表，逗号分隔）
CORS_ORIGINS=http://localhost:3000
# 允许的来源正则（默认放通任何 localhost/127.0.0.1:port，适配 Windsurf Preview 代理）
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
